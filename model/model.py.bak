import pandas as pd
import numpy as np
import logging
import warnings
import sys

if not sys.warnoptions:
    warnings.simplefilter("ignore")

import xgboost as xgb

# Label mapping từ split_metadata.json
LABEL_MAPPING = {
    0: "Benign",
    1: "Analysis",
    2: "Backdoor",
    3: "DoS",
    4: "Exploits",
    5: "Fuzzers",
    6: "Generic",
    7: "Reconnaissance",
    8: "Shellcode",
    9: "Worms",
}

# 76 features theo đúng thứ tự trong split_metadata.json
FEATURES = [
    "Flow Duration", "Total Fwd Packet", "Total Bwd packets",
    "Total Length of Fwd Packet", "Total Length of Bwd Packet",
    "Fwd Packet Length Max", "Fwd Packet Length Min", "Fwd Packet Length Mean",
    "Fwd Packet Length Std", "Bwd Packet Length Max", "Bwd Packet Length Min",
    "Bwd Packet Length Mean", "Bwd Packet Length Std", "Flow Bytes/s",
    "Flow Packets/s", "Flow IAT Mean", "Flow IAT Std", "Flow IAT Max",
    "Flow IAT Min", "Fwd IAT Total", "Fwd IAT Mean", "Fwd IAT Std",
    "Fwd IAT Max", "Fwd IAT Min", "Bwd IAT Total", "Bwd IAT Mean",
    "Bwd IAT Std", "Bwd IAT Max", "Bwd IAT Min", "Fwd PSH Flags",
    "Bwd PSH Flags", "Fwd URG Flags", "Bwd URG Flags", "Fwd Header Length",
    "Bwd Header Length", "Fwd Packets/s", "Bwd Packets/s", "Packet Length Min",
    "Packet Length Max", "Packet Length Mean", "Packet Length Std",
    "Packet Length Variance", "FIN Flag Count", "SYN Flag Count",
    "RST Flag Count", "PSH Flag Count", "ACK Flag Count", "URG Flag Count",
    "CWR Flag Count", "ECE Flag Count", "Down/Up Ratio", "Average Packet Size",
    "Fwd Segment Size Avg", "Bwd Segment Size Avg", "Fwd Bytes/Bulk Avg",
    "Fwd Packet/Bulk Avg", "Fwd Bulk Rate Avg", "Bwd Bytes/Bulk Avg",
    "Bwd Packet/Bulk Avg", "Bwd Bulk Rate Avg", "Subflow Fwd Packets",
    "Subflow Fwd Bytes", "Subflow Bwd Packets", "Subflow Bwd Bytes",
    "FWD Init Win Bytes", "Bwd Init Win Bytes", "Fwd Act Data Pkts",
    "Fwd Seg Size Min", "Active Mean", "Active Std", "Active Max",
    "Active Min", "Idle Mean", "Idle Std", "Idle Max", "Idle Min",
]

ALL_FEATURES_PATH = "./all_features.txt"
MODEL_PATH        = "./xgboost_v1.json"


class model:
    def __init__(self):
        self.label_mapping = LABEL_MAPPING

        # Load XGBoost model
        try:
            self.xgb_model = xgb.XGBClassifier()
            self.xgb_model.load_model(MODEL_PATH)
            logging.info(f"XGBoost model loaded from {MODEL_PATH}")
        except Exception as e:
            logging.error(f"Cannot load XGBoost model: {e}")
            raise

        # Load all_features để parse dữ liệu thô từ socket
        try:
            self.all_features = open(ALL_FEATURES_PATH, "r").readline().split(",")
            logging.info(f"all_features loaded: {len(self.all_features)} columns")
        except Exception as e:
            logging.error(f"Cannot load {ALL_FEATURES_PATH}: {e}")
            raise

        self.features = FEATURES  # 76 features dùng cho model
        self.data     = None

    def load_data(self, rows: str):
        """Parse chuỗi nhận từ server.py qua socket TCP.
        Định dạng: <csv_flow_1>bpoint<csv_flow_2>bpoint...
        """
        records = [
            x.strip(",").split(",")
            for x in rows.strip("bpoint").split("bpoint")
            if x.strip(",")
        ]
        df = pd.DataFrame(records, columns=self.all_features)
        self.data = self._preprocess(df)

    def load_data_csv(self, path: str = "./data_examples/example.csv"):
        """Load từ file CSV — dùng để đánh giá offline."""
        df = pd.read_csv(path)
        self.label = df["Label"].to_numpy() if "Label" in df.columns else None
        self.data = self._preprocess(df)

    def _preprocess(self, df: pd.DataFrame) -> np.ndarray:
        df = df[self.features]
        df = df.replace([np.inf, -np.inf], np.nan).dropna()
        df = df.astype("float")
        return df.to_numpy()

    def predict(self) -> list:
        if self.data is None or len(self.data) == 0:
            logging.warning("No data to predict.")
            return []
        preds = self.xgb_model.predict(self.data).astype("int32")
        return [self.label_mapping.get(p, f"Unknown({p})") for p in preds]

    def accuracy(self) -> float | None:
        if not hasattr(self, "label") or self.label is None:
            logging.error("No label available. Use load_data_csv() with a labeled CSV.")
            return None
        from sklearn.metrics import accuracy_score
        preds = self.xgb_model.predict(self.data).astype("int32")
        return accuracy_score(self.label, preds)